{
  "name": "@gent/tui",
  "version": "0.0.0",
  "bin": {
    "gent": "bin/gent"
  },
  "type": "module",
  "scripts": {
    "dev": "bun --preload ./node_modules/@opentui/solid/scripts/preload.ts src/main.tsx",
    "build": "env -u FORCE_COLOR NO_COLOR=1 bun scripts/build.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "env -u FORCE_COLOR NO_COLOR=1 effect-language-service diagnostics --project tsconfig.json",
    "test": "env -u FORCE_COLOR NO_COLOR=1 bun test --preload ./node_modules/@opentui/solid/scripts/preload.ts tests integration"
  },
  "dependencies": {
    "@effect/platform-bun": "catalog:",
    "@ff-labs/fff-bun": "catalog:",
    "@gent/core": "workspace:*",
    "@gent/extensions": "workspace:*",
    "@gent/sdk": "workspace:*",
    "@opentui/core": "^0.1.102",
    "@opentui/solid": "^0.1.102",
    "beautiful-mermaid": "^1.1.3",
    "diff": "^9.0.0",
    "solid-js": "catalog:"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "zigpty": "^0.1.6"
  },
  "peerDependencies": {
    "effect": "catalog:"
  }
}

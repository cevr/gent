{
  "name": "gent",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "effect-language-service patch && turbo run typecheck --force",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build": "turbo run build",
    "test": "turbo run test && bun test ./tests/*.test.ts",
    "test:seams": "bun test tests/transport-contract.test.ts tests/event-stream-parity.test.ts tests/live-event-parity.test.ts tests/watch-state-parity.test.ts tests/queue-contract.test.ts && (cd apps/tui && bun test --preload ./node_modules/@opentui/solid/scripts/preload.ts tests/worker-supervisor.test.ts tests/session-feed-boundary.test.tsx tests/app-bootstrap-boundary.test.ts)",
    "gate": "concurrently -n type,lint,fmt,build,test -c blue,yellow,magenta,cyan,green \"bun run typecheck\" \"bun run lint\" \"bun run fmt\" \"bun run build\" \"bun run test\"",
    "clean": "rm -rf .turbo */.turbo */*/.turbo",
    "smoke": "bun run --cwd apps/tui dev -H 'Say hi in 3 words'",
    "prepare": "effect-language-service patch && lefthook install"
  },
  "dependencies": {
    "effect-machine": "catalog:",
    "msgpackr": "catalog:",
    "multipasta": "catalog:"
  },
  "devDependencies": {
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/mistral": "catalog:",
    "@effect/language-service": "^0.81.0",
    "@effect/platform-bun": "catalog:",
    "@effect/sql-pg": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@types/bun": "^1.3.11",
    "concurrently": "^9.2.1",
    "effect": "catalog:",
    "effect-bun-test": "0.2.1",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.6",
  "catalog": {
    "effect": "4.0.0-beta.35",
    "@effect/platform-bun": "4.0.0-beta.35",
    "@effect/sql-pg": "4.0.0-beta.35",
    "@effect/sql-sqlite-bun": "4.0.0-beta.35",
    "effect-machine": "file:/Users/cvr/Developer/personal/effect-machine",
    "msgpackr": "^1.11.9",
    "multipasta": "^0.2.7",
    "ai": "^6.0.134",
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/openai": "^3.0.47",
    "@ai-sdk/google": "^3.0.52",
    "@ai-sdk/mistral": "^3.0.27",
    "effect-bun-test": "0.2.1",
    "solid-js": "^1.9.11"
  }
}

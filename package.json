{
  "name": "gent",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "turbo run typecheck",
    "lint": "concurrently -n oxlint,effect -c yellow,blue \"oxlint\" \"turbo run lint\"",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "gate": "concurrently -n type,lint,fmt,build,test -c blue,yellow,magenta,cyan,green \"bun run typecheck\" \"bun run lint\" \"bun run fmt\" \"bun run build\" \"bun run test\"",
    "clean": "rm -rf .turbo */.turbo */*/.turbo",
    "smoke": "bun run --cwd apps/tui dev -H 'Say hi in 3 words'",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "effect-machine": "catalog:",
    "msgpackr": "catalog:",
    "multipasta": "catalog:"
  },
  "devDependencies": {
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/mistral": "catalog:",
    "@effect/language-service": "^0.84.3",
    "@effect/platform-bun": "catalog:",
    "@effect/sql-pg": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@types/bun": "^1.3.11",
    "concurrently": "^9.2.1",
    "effect": "catalog:",
    "effect-bun-test": "catalog:",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "effect": "4.0.0-beta.43"
  },
  "packageManager": "bun@1.3.6",
  "catalog": {
    "effect": "4.0.0-beta.43",

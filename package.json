{
  "name": "gent",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "turbo run typecheck",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build": "turbo run build",
    "test": "turbo run test && bun test tests",
    "gate": "concurrently -n type,lint,fmt,build,test -c blue,yellow,magenta,cyan,green \"bun run typecheck\" \"bun run lint\" \"bun run fmt\" \"bun run build\" \"bun run test\"",
    "clean": "rm -rf .turbo */.turbo */*/.turbo",
    "smoke": "bun run --cwd apps/tui dev -H 'Say hi in 3 words'",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.73",
    "@aws-sdk/credential-providers": "^3.1001.0",
    "effect-machine": "catalog:",
    "msgpackr": "catalog:",
    "multipasta": "catalog:"
  },
  "devDependencies": {
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/mistral": "catalog:",
    "@effect/language-service": "^0.75.1",
    "@effect/platform-bun": "catalog:",
    "@effect/sql-pg": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@types/bun": "^1.3.10",
    "concurrently": "^9.2.1",
    "effect": "catalog:",
    "effect-bun-test": "0.2.1",
    "lefthook": "^2.1.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.6",
  "catalog": {
    "effect": "4.0.0-beta.26",
    "@effect/platform-bun": "4.0.0-beta.26",
    "@effect/sql-pg": "4.0.0-beta.26",
    "@effect/sql-sqlite-bun": "4.0.0-beta.26",
    "effect-machine": "0.7.2",
    "msgpackr": "^1.11.4",
    "multipasta": "^0.2.7",
    "ai": "^6.0.111",
    "@ai-sdk/anthropic": "^3.0.54",
    "@ai-sdk/openai": "^3.0.39",
    "@ai-sdk/google": "^3.0.37",
    "@ai-sdk/mistral": "^3.0.22",
    "effect-bun-test": "0.2.1"
  }
}

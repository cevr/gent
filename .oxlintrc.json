{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "plugins": ["typescript", "import", "node"],
  "jsPlugins": ["./lint/no-direct-env.ts"],
  "rules": {
    // Custom — use Config from effect, not direct env access
    "gent/no-direct-env": "error",
    // Custom — no positional error args in Effect.log*
    "gent/no-positional-log-error": "error",
    // Custom — extensions must not import from runtime/, storage/, server/
    "gent/no-extension-internal-imports": "error",
    // TypeScript - no any
    "typescript/no-explicit-any": "error",

    // TypeScript - no non-null assertions
    "typescript/no-non-null-assertion": "error",
    "typescript/no-extra-non-null-assertion": "error",
    "typescript/no-non-null-asserted-optional-chain": "error",

    // TypeScript - consistent type imports
    "typescript/consistent-type-imports": [
      "error",
      { "prefer": "type-imports", "fixStyle": "separate-type-imports" }
    ],

    // Import rules
    "import/no-duplicates": "error",

    // Node rules
    "node/no-process-env": "error",

    // Unused vars
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],

    // Readability
    "no-nested-ternary": "error",
    "complexity": ["error", 20],

    // Disabled — false positives with TS enums, type imports, etc.
    "no-shadow": "off"
  },
  "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/*.d.ts", "**/scripts/**"],
  "overrides": [
    {
      "files": ["**/*.tsx"],
      "rules": {}
    },
    {
      "files": ["**/tests/**", "**/*.test.ts", "**/*.test.tsx"],
      "rules": {
        "typescript/no-non-null-assertion": "off",
        "typescript/no-explicit-any": "off"
      }
    },
    {
      "files": [
        "**/extensions/anthropic/**",
        "**/extensions/openai/**",
        "**/extensions/bedrock/**",
        "**/extensions/google/**",
        "**/extensions/mistral/**"
      ],
      "rules": {
        "node/no-process-env": "off",
        "gent/no-direct-env": "off"
      }
    }
  ]
}

{
  "name": "@gent/core",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./domain/*": "./src/domain/*",
    "./domain/extension": null,
    "./domain/extension.js": null,
    "./domain/extension.ts": null,
    "./debug/*": "./src/debug/*",
    "./storage/*": "./src/storage/*",
    "./providers/*": "./src/providers/*",
    "./runtime/extensions/internal-resource-machine": null,
    "./runtime/extensions/internal-resource-machine.js": null,
    "./runtime/extensions/internal-resource-machine.ts": null,
    "./runtime/extensions/runtime-effect": null,
    "./runtime/extensions/runtime-effect.js": null,
    "./runtime/extensions/runtime-effect.ts": null,
    "./runtime/extensions/turn-control": null,
    "./runtime/extensions/turn-control.js": null,
    "./runtime/extensions/turn-control.ts": null,
    "./runtime/*": "./src/runtime/*",
    "./extensions/api": "./src/extensions/api.ts",
    "./server/*": "./src/server/*",
    "./test-utils": "./src/test-utils/index.ts",
    "./test-utils/*": "./src/test-utils/*"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit && tsgo --noEmit -p tsconfig.locks.json",
    "lint": "env -u FORCE_COLOR NO_COLOR=1 effect-language-service diagnostics --project tsconfig.json",
    "test": "env -u FORCE_COLOR NO_COLOR=1 bun test tests/"
  },
  "dependencies": {
    "effect-machine": "catalog:",
    "effect-wide-event": "catalog:"
  },
  "peerDependencies": {
    "@effect/platform-bun": "catalog:",
    "@effect/sql-pg": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "effect": "catalog:",
    "effect-bun-test": "catalog:"
  },
  "optionalDependencies": {
    "@ff-labs/fff-bun": "catalog:"
  }
}

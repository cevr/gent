    "./debug/*": "./src/debug/*",
    "./storage/*": "./src/storage/*",
    "./providers/*": "./src/providers/*",
    "./runtime/*": "./src/runtime/*",
    "./extensions/api": "./src/extensions/api.ts",
    "./server/*": "./src/server/*",

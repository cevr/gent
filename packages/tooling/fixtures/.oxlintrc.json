{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "off",
    "suspicious": "off",
    "perf": "off"
  },
  "plugins": [],
  "jsPlugins": ["../../../lint/no-direct-env.ts"],
  "rules": {
    "gent/no-runpromise-outside-boundary": "error",
    "gent/all-errors-are-tagged": "error",
    "gent/no-define-extension-throw": "error",
    "gent/no-r-equals-never-comment": "error",
    "gent/brand-constructor-callers": "error",
    "gent/no-scope-brand-cast": "error"
  }
}
